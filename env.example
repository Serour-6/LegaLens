# LegalLens — Environment Variables
# Copy this file to .env and fill in your keys
# NEVER commit .env to git

# ── Primary LLM: Google Gemini 2.5 Flash ───────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── Q&A LLM: Groq (Llama 3.3 70B) ─────────────────────────────────────────
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Embeddings: Cohere Embed v3 ─────────────────────────────────────────────
# Get from: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your_cohere_api_key_here

# ── Auth0 (Authentication) ──────────────────────────────────────────────────
# Get from: https://manage.auth0.com → Applications → Your App → Settings
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_client_id_here
AUTH0_CLIENT_SECRET=your_client_secret_here
AUTH0_AUDIENCE=https://legallens.api

# ── Fallback LLM: Mistral (optional) ───────────────────────────────────────
# Get from: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your_mistral_api_key_here

# ── Voice Agent: ElevenLabs + Hotword (optional) ───────────────────────────
# Backend voice session (FastAPI + ElevenLabs)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
AGENT_ID=your_elevenlabs_agent_id_here
# Internal key used by the /api/voice/session route so only trusted clients
# (e.g. your own frontend or hotword listener) can start a voice session.
VOICE_AGENT_API_KEY=dev-voice-agent-key

# Local hotword listener (Picovoice Porcupine)
# Picovoice access key to run Porcupine locally:
PICOVOICE_ACCESS_KEY=your_picovoice_access_key_here
# Optional: path to a custom "Hey Assistant" Porcupine keyword (.ppn) file
PORCUPINE_KEYWORD_PATH=/absolute/path/to/hey-assistant.ppn
# Optional override for where the hotword listener should call the backend:
VOICE_SESSION_URL=http://localhost:8000/api/voice/session
